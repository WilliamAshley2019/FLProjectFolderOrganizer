/**
 * Handles safe loading and metadata extraction of audio plugins.
 * Uses JUCE's AudioPluginFormatManager and optionally a separate process.
 */
class PluginHostingModule
{
public:
    struct PluginDescription
    {
        juce::String name;
        juce::String vendor;
        juce::String version;
        juce::String uid;          // Unique ID (e.g., VST3 UID)
        juce::String format;       // "VST2", "VST3", "AU", "CLAP"
        bool isInstrument = false;
        bool isVerified = false;
        int loadTimeMs = 0;
        juce::String errorMessage;
    };

    PluginHostingModule();
    ~PluginHostingModule();

    // Loads a plugin file and extracts its description.
    // Returns true if successful; error message is set otherwise.
    bool LoadAndExtractInfo(const juce::File& pluginFile, PluginDescription& outDesc);

    // Quick test to see if plugin can be loaded without extracting full info.
    bool QuickTestLoad(const juce::File& pluginFile, juce::String& outError);

    // Extracts metadata from VST3 bundle without loading the DLL (fast scan).
    static bool ExtractVST3Metadata(const juce::File& bundleFile, PluginDescription& outDesc);

private:
