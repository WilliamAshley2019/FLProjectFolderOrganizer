    searchPathEditor.setBounds(row2.removeFromLeft(row2.getWidth() - 60));
    addPathButton.setBounds(row2.removeFromRight(30));
    removePathButton.setBounds(row2.removeFromRight(30));

    // Row 3: Filter
    auto row3 = top.removeFromTop(30);
    filterEditor.setBounds(row3);

    // Table and log split
    auto split = area;
    auto tableArea = split.removeFromTop(split.getHeight() * 0.7f);
    pluginTable.setBounds(tableArea);

    auto statusArea = split.removeFromTop(30);
    statusLabel.setBounds(statusArea.removeFromLeft(200));
    progressBar.setBounds(statusArea);

    auto logArea = split;
    logBox.setBounds(logArea);
}

void PluginManagerEditor::timerCallback()
{
    // Process logs
    juce::ScopedLock sl(logLock);
    if (!pendingLogs.isEmpty())
    {
        for (const auto& msg : pendingLogs)
        {
            logBox.moveCaretToEnd();
            logBox.insertTextAtCaret(msg + "\n");
        }
        pendingLogs.clear();
        logBox.moveCaretToEnd();
    }
}

