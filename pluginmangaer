// ---- UI actions ----
void PluginManagerEditor::refreshTable()
{
    // Filter
    juce::String filter = filterEditor.getText().trim();
    auto all = database.GetAllPlugins();
    displayRows.clear();
    for (const auto& p : all)
    {
        if (filter.isEmpty() ||
            p.name.containsIgnoreCase(filter) ||
            p.vendor.containsIgnoreCase(filter) ||
            p.format.containsIgnoreCase(filter))
        {
            displayRows.push_back(p);
        }
    }
    // Sort again
    sortOrderChanged(sortColumn, sortForwards);
    pluginTable.updateContent();
}

void PluginManagerEditor::startScan()
{
    if (searchPaths.isEmpty())
    {
        juce::AlertWindow::showMessageBoxAsync(juce::AlertWindow::WarningIcon,
            "No paths", "Please add at least one plugin search path.");
        return;
    }

    scanner = std::make_unique<PluginsScanner>();
    scanner->onLog = [this](const juce::String& msg) { sendLog(msg); };
    scanner->onProgress = [this](float progress, const juce::String& status) {
        currentProgress = progress;
        statusLabel.setText(status, juce::dontSendNotification);
    };
    scanner->onPluginFound = [this](const PluginDatabaseManager::PluginInfo& info) {
        juce::MessageManager::callAsync([this] { refreshTable(); });
    };
    scanner->onPluginCrash = [this](const juce::String& path, const juce::String& error) {
        sendLog("CRASH: " + path + " - " + error);
    };

    scanner->Scan(searchPaths, true, combineToggle.getToggleState(), true);
    isScanning = true;
    updateUIState();
}

void PluginManagerEditor::stopScan()
{
    if (scanner)
        scanner->StopScanning();
    isScanning = false;
    updateUIState();
}

