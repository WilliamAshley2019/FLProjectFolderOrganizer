bool PluginDatabaseManager::AddOrUpdatePlugin(const PluginInfo& info)
{
    if (db == nullptr) return false;

    const char* sql = R"(
        INSERT OR REPLACE INTO plugins
        (path, name, vendor, version, uid, format, is_instrument, is_verified, is_enabled, is_missing, hash, load_time_ms, error_message, last_scanned, updated_at)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP)
    )";

    sqlite3_stmt* stmt = nullptr;
    if (sqlite3_prepare_v2(db, sql, -1, &stmt, nullptr) != SQLITE_OK)
        return false;

    bindText(stmt, 1, info.path);
    bindText(stmt, 2, info.name);
    bindText(stmt, 3, info.vendor);
    bindText(stmt, 4, info.version);
    bindText(stmt, 5, info.uid);
    bindText(stmt, 6, info.format);
    bindInt(stmt, 7, info.isInstrument ? 1 : 0);
    bindInt(stmt, 8, info.isVerified ? 1 : 0);
    bindInt(stmt, 9, info.isEnabled ? 1 : 0);
    bindInt(stmt, 10, info.isMissing ? 1 : 0);
    bindText(stmt, 11, info.hash);
    bindInt(stmt, 12, info.loadTimeMs);
    bindText(stmt, 13, info.errorMessage);

    bool ok = sqlite3_step(stmt) == SQLITE_DONE;
    sqlite3_finalize(stmt);
    return ok;
}

