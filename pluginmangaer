void PluginManagerEditor::showContextMenu(int row, juce::Point<int> screenPos)
{
    if (row < 0 || row >= (int)displayRows.size()) return;
    const auto& info = displayRows[row];

    juce::PopupMenu menu;
    menu.addItem(1, "Open Containing Folder");
    menu.addItem(2, "Toggle Enabled");
    menu.addItem(3, "Mark as Instrument");
    menu.addItem(4, "Mark as Effect");
    menu.addItem(5, "Verify Now");

    menu.showMenuAsync(juce::PopupMenu::Options().withTargetScreenArea(
        juce::Rectangle<int>(screenPos, screenPos)),
        [this, row](int result)
        {
            if (result == 1) openContainingFolder(row);
            else if (result == 2) togglePluginEnabled(row);
            else if (result == 3) markAsInstrument(row);
            else if (result == 4) markAsEffect(row);
            else if (result == 5) verifySelected();
        });
}
