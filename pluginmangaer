// ---- Row converters ----
PluginDatabaseManager::PluginInfo PluginDatabaseManager::rowToPluginInfo(sqlite3_stmt* stmt)
{
    PluginInfo info;
    auto getText = [&](int col) -> juce::String {
        const char* t = (const char*)sqlite3_column_text(stmt, col);
        return t ? juce::String::fromUTF8(t) : juce::String();
    };
    info.id             = sqlite3_column_int(stmt, 0);
    info.path           = getText(1);
    info.name           = getText(2);
    info.vendor         = getText(3);
    info.version        = getText(4);
    info.uid            = getText(5);
    info.format         = getText(6);
    info.isInstrument   = sqlite3_column_int(stmt, 7) != 0;
    info.isVerified     = sqlite3_column_int(stmt, 8) != 0;
    info.isEnabled      = sqlite3_column_int(stmt, 9) != 0;
    info.isMissing      = sqlite3_column_int(stmt, 10) != 0;
    info.hash           = getText(11);
    info.loadTimeMs     = sqlite3_column_int(stmt, 12);
    info.errorMessage   = getText(13);
    info.lastScanned    = juce::Time(sqlite3_column_int64(stmt, 14) * 1000); // SQLite stores as seconds since epoch
    // created_at and updated_at are not used in the struct
    return info;
}

