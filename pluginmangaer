#include "PluginDatabaseManager.h"
#include "sqlite3.h"

PluginDatabaseManager::PluginDatabaseManager() {}
PluginDatabaseManager::~PluginDatabaseManager()
{
    Close();
}

bool PluginDatabaseManager::Initialize(const juce::File& dbFile)
{
    if (db != nullptr)
        return true; // Already open

    auto pathUTF8 = dbFile.getFullPathName().toUTF8();
    int rc = sqlite3_open(pathUTF8, &db);
    if (rc != SQLITE_OK)
    {
        db = nullptr;
        return false;
    }

    ExecuteSQL("PRAGMA foreign_keys = ON;");
    ExecuteSQL("PRAGMA journal_mode = WAL;");
    return CreateTables();
}

bool PluginDatabaseManager::Close()
{
    if (db != nullptr)
    {
        sqlite3_close(db);
        db = nullptr;
    }
    return true;
}

bool PluginDatabaseManager::ExecuteSQL(const juce::String& sql)
{
    if (db == nullptr) return false;
    char* errMsg = nullptr;
    int rc = sqlite3_exec(db, sql.toUTF8(), nullptr, nullptr, &errMsg);
    if (errMsg)
    {
        // Optionally log the error
        sqlite3_free(errMsg);
    }
    return rc == SQLITE_OK;
}

bool PluginDatabaseManager::CreateTables()
{
    const char* createPlugins = R"(
        CREATE TABLE IF NOT EXISTS plugins (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            path TEXT UNIQUE NOT NULL,
            name TEXT,
            vendor TEXT,
            version TEXT,
            uid TEXT,
            format TEXT,
            is_instrument INTEGER DEFAULT 0,
            is_verified INTEGER DEFAULT 0,
            is_enabled INTEGER DEFAULT 1,
            is_missing INTEGER DEFAULT 0,
            hash TEXT,
            load_time_ms INTEGER DEFAULT 0,
            error_message TEXT,
            last_scanned DATETIME DEFAULT CURRENT_TIMESTAMP,
            created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
        )
    )";

    const char* createPresets = R"(
        CREATE TABLE IF NOT EXISTS presets (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            plugin_uid TEXT NOT NULL,
            path TEXT UNIQUE NOT NULL,
            name TEXT,
            category TEXT,
            tags TEXT,
            hash TEXT,
            last_scanned DATETIME DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY(plugin_uid) REFERENCES plugins(uid) ON DELETE CASCADE
        )
    )";

    const char* createDependencies = R"(
        CREATE TABLE IF NOT EXISTS dependencies (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            plugin_uid TEXT NOT NULL,
            dependency_type TEXT,
            path TEXT,
            is_available INTEGER DEFAULT 0,
            last_checked DATETIME DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY(plugin_uid) REFERENCES plugins(uid) ON DELETE CASCADE
        )
    )";

    if (!ExecuteSQL(createPlugins)) return false;
    ExecuteSQL("CREATE INDEX IF NOT EXISTS idx_plugins_uid ON plugins(uid);");
    ExecuteSQL("CREATE INDEX IF NOT EXISTS idx_plugins_format ON plugins(format);");
    ExecuteSQL("CREATE INDEX IF NOT EXISTS idx_plugins_vendor ON plugins(vendor);");

    if (!ExecuteSQL(createPresets)) return false;
    ExecuteSQL("CREATE INDEX IF NOT EXISTS idx_presets_plugin_uid ON presets(plugin_uid);");
    ExecuteSQL("CREATE INDEX IF NOT EXISTS idx_presets_category ON presets(category);");

    if (!ExecuteSQL(createDependencies)) return false;
    ExecuteSQL("CREATE INDEX IF NOT EXISTS idx_deps_plugin_uid ON dependencies(plugin_uid);");

    return true;
}

