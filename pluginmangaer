void PluginsScanner::Scan(const juce::StringArray& paths,
                          bool deepScan,
                          bool combine,
                          bool deleteMissing)
{
    searchPaths = paths;
    performDeepScan = deepScan;
    combineVST2AndVST3 = combine;
    deleteMissing = deleteMissing;
    totalScanned = 0;
    verifiedCount = 0;
    unverifiedCount = 0;
    crashCount = 0;
    stopScanning = false;

    startThread();
}

void PluginsScanner::StopScanning()
{
    stopScanning = true;
}

void PluginsScanner::run()
{
    SendLog("Starting plugin scan...");

    // First, gather all plugin files from search paths
    juce::Array<juce::File> pluginFiles;
    for (const auto& path : searchPaths)
    {
        juce::File dir(path);
        if (!dir.isDirectory())
        {
            SendLog("Skipping invalid directory: " + path);
            continue;
        }

        // Recursively find plugin files based on extensions
        juce::Array<juce::File> found;
        dir.findChildFiles(found, juce::File::findFiles, true, "*.dll;*.vst3;*.component;*.clap;*.aaxplugin");
        pluginFiles.addArray(found);
    }

    // Also check for VST3 bundles (which are directories) - findChildFiles with findDirectories and pattern *.vst3
    // But we already included *.vst3 in findFiles? Actually findFiles with *.vst3 will not find directories.
    // We need to separately find directories ending with .vst3 or .component
    for (const auto& path : searchPaths)
    {
        juce::File dir(path);
        if (!dir.isDirectory()) continue;
        juce::Array<juce::File> subDirs;
        dir.findChildFiles(subDirs, juce::File::findDirectories, true, "*.vst3;*.component");
        pluginFiles.addArray(subDirs);
    }

    SendLog("Found " + juce::String(pluginFiles.size()) + " potential plugin files/directories.");

    int total = pluginFiles.size();
    int processed = 0;

    for (const auto& file : pluginFiles)
    {
        if (stopScanning) break;

        ProcessPluginFile(file);
        processed++;
        float progress = (float)processed / (float)total;
        SendProgress(progress, "Scanning " + file.getFileName());

        // Update status count every few items
        if (processed % 10 == 0)
        {
            SendLog("Scanned " + juce::String(processed) + "/" + juce::String(total) +
                    " files. Verified: " + juce::String(verifiedCount.load()) +
                    ", Unverified: " + juce::String(unverifiedCount.load()));
        }
    }

    // Optionally, after scan, combine duplicates if requested
    if (combineVST2AndVST3)
    {
        SendLog("Combining VST2 and VST3 duplicates...");
        auto duplicates = database.FindDuplicatesByUID();
        for (const auto& plugin : duplicates)
        {
            if (stopScanning) break;
            database.CombineVST2AndVST3(plugin.uid);
        }
    }

    // Mark missing plugins if requested
    if (deleteMissing)
    {
        SendLog("Checking for missing plugins...");
        auto all = database.GetAllPlugins();
        for (const auto& info : all)
        {
            if (stopScanning) break;
            juce::File f(info.path);
            if (!f.exists())
            {
                database.MarkPluginAsMissing(info.path);
                SendLog("Marked as missing: " + info.path);
            }
        }
    }

    SendProgress(1.0f, "Scan complete.");
    SendLog("Scan complete. Verified: " + juce::String(verifiedCount.load()) +
            ", Unverified: " + juce::String(unverifiedCount.load()) +
            ", Crashes: " + juce::String(crashCount.load()));
}

void PluginsScanner::ProcessPluginFile(const juce::File& file)
{
    // Skip if it's not a plugin file/directory
    if (ShouldSkipFile(file))
        return;

    // Compute a fast hash for change detection
    juce::String hash = CalculateFileHash(file);

    // Check if we already have this plugin in DB
    auto existing = database.GetPluginByUID(juce::String()); // We need to find by path instead
    // Actually, we need to find by path first to compare hash.
    // Let's load all plugins and check by path.
    auto all = database.GetAllPlugins();
    bool found = false;
    for (const auto& p : all)
    {
        if (p.path == file.getFullPathName())
        {
            found = true;
            if (p.hash == hash && p.isVerified)
            {
                // No change, skip verification unless user requested deep scan
                if (!performDeepScan)
                {
                    // Just update last scanned
                    PluginDatabaseManager::PluginInfo info = p;
                    info.lastScanned = juce::Time::getCurrentTime();
                    database.AddOrUpdatePlugin(info);
                    return;
                }
            }
            // else need to verify
            break;
        }
    }

    // Prepare a new plugin info
    PluginDatabaseManager::PluginInfo info;
    info.path = file.getFullPathName();
    info.hash = hash;
    info.format = GetPluginFormat(file);
    info.lastScanned = juce::Time::getCurrentTime();

    // Extract metadata
    if (performDeepScan)
    {
        VerifyPlugin(info);
    }
    else
    {
        // Fast scan: just get basic info from file name and format
        info.name = file.getFileNameWithoutExtension();
        info.vendor = "Unknown";
        info.version = "0.0.0";
        info.uid = info.path; // use path as fallback
        info.isVerified = false;
    }

    // Update database
    database.AddOrUpdatePlugin(info);
    totalScanned++;

    if (info.isVerified)
        verifiedCount++;
    else
        unverifiedCount++;

    if (onPluginFound)
        onPluginFound(info);
}

void PluginsScanner::VerifyPlugin(PluginDatabaseManager::PluginInfo& info)
{
    PluginHostingModule::PluginDescription desc;
    bool success = hostingModule.LoadAndExtractInfo(juce::File(info.path), desc);

    if (!success)
    {
        info.isVerified = false;
        info.errorMessage = desc.errorMessage;
        // Maybe a crash
        if (desc.errorMessage.containsIgnoreCase("crash") || desc.errorMessage.containsIgnoreCase("access violation"))
        {
            crashCount++;
            if (onPluginCrash)
                onPluginCrash(info.path, desc.errorMessage);
        }
        return;
    }

    info.name = desc.name;
    info.vendor = desc.vendor;
    info.version = desc.version;
    info.uid = desc.uid;
    info.isInstrument = desc.isInstrument;
    info.isVerified = true;
    info.loadTimeMs = desc.loadTimeMs;
    info.errorMessage.clear();

    // If format was not determined, we can set it from desc
    if (info.format.isEmpty())
        info.format = desc.format;
}

juce::String PluginsScanner::CalculateFileHash(const juce::File& file)
{
    // Use a fast hash (e.g., xxHash) or SHA-256 if you have it.
    // For simplicity, we'll use a simple file size + last modified time
    // but a real hash would be better.
    return juce::String(file.getSize()) + "_" + juce::String(file.getLastModificationTime().toMilliseconds());
    // In practice, use a proper hash function.
}

bool PluginsScanner::ShouldSkipFile(const juce::File& file)
{
    // Skip if file is hidden or system
    if (file.isHidden() || file.isSymbolicLink())
        return true;

    // Skip if it's a VST3 bundle but missing the main DLL?
    // VST3 bundles are directories; we can check for the .vst3 extension and that it's a directory.
    // We'll just accept them.
    return false;
}

juce::String PluginsScanner::GetPluginFormat(const juce::File& file)
{
    if (file.isDirectory())
    {
        if (file.getFileExtension() == ".vst3") return "VST3";
        if (file.getFileExtension() == ".component") return "AU";
        if (file.getFileExtension() == ".aaxplugin") return "AAX";
        return "Unknown";
    }
    else
    {
        juce::String ext = file.getFileExtension();
        if (ext == ".dll") return "VST2";
        if (ext == ".vst3") return "VST3"; // could be a file? Usually not
        if (ext == ".component") return "AU";
        if (ext == ".clap") return "CLAP";
        if (ext == ".aaxplugin") return "AAX";
        return "Unknown";
    }
}

void PluginsScanner::SendLog(const juce::String& msg)
{
    if (onLog) onLog(msg);
}

void PluginsScanner::SendProgress(float progress, const juce::String& status)
{
    if (onProgress) onProgress(progress, status);
}
