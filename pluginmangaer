/**
 * Background thread for scanning plugin directories, verifying plugins,
 * and updating the plugin database.
 */
class PluginsScanner : public juce::Thread
{
public:
    PluginsScanner();
    ~PluginsScanner() override;

    // Start scanning with given search paths.
    // If performDeepScan is true, loads each plugin to extract metadata.
    // If combineVST2AndVST3 is true, merges duplicates.
    // If deleteMissing is true, removes entries for missing files.
    void Scan(const juce::StringArray& searchPaths,
              bool performDeepScan,
              bool combineVST2AndVST3,
              bool deleteMissing);

    void StopScanning();

    // Callbacks
    std::function<void(const juce::String&)> onLog;
    std::function<void(float, const juce::String&)> onProgress; // progress (0-1), status message
    std::function<void(const PluginDatabaseManager::PluginInfo&)> onPluginFound;
    std::function<void(const juce::String&, const juce::String&)> onPluginCrash; // path, error

    int GetTotalScanned() const { return totalScanned; }
    int GetVerifiedCount() const { return verifiedCount; }
    int GetUnverifiedCount() const { return unverifiedCount; }
    int GetCrashCount() const { return crashCount; }

private:
    void run() override;
    void ProcessPluginFile(const juce::File& file);
    void VerifyPlugin(PluginDatabaseManager::PluginInfo& info);
    void UpdatePluginInfo(const PluginDatabaseManager::PluginInfo& info);
    juce::String CalculateFileHash(const juce::File& file);
    bool ShouldSkipFile(const juce::File& file);
    juce::String GetPluginFormat(const juce::File& file);

    void SendLog(const juce::String& msg);
    void SendProgress(float progress, const juce::String& status);

    PluginDatabaseManager database;
    juce::StringArray searchPaths;
    bool performDeepScan = true;
    bool combineVST2AndVST3 = false;
    bool deleteMissing = false;
    bool stopScanning = false;
    std::atomic<int> totalScanned{0};
    std::atomic<int> verifiedCount{0};
    std::atomic<int> unverifiedCount{0};
    std::atomic<int> crashCount{0};

    juce::CriticalSection progressLock;
    float lastProgress = 0.0f;
    juce::String lastStatus;

    PluginHostingModule hostingModule;
};
