void PluginManagerEditor::paintCell(juce::Graphics& g, int rowNumber, int columnId,
    int width, int height, bool rowIsSelected)
{
    if (rowNumber >= (int)displayRows.size()) return;

    const auto& info = displayRows[rowNumber];
    juce::String text;

    switch (columnId)
    {
    case 1: text = info.name; break;
    case 2: text = info.vendor; break;
    case 3: text = info.version; break;
    case 4: text = info.format; break;
    case 5: text = info.isInstrument ? "Instrument" : "Effect"; break;
    case 6:
        if (info.isMissing) text = "Missing";
        else if (info.isVerified) text = "Verified";
        else text = "Unverified";
        break;
    case 7: text = juce::String(info.loadTimeMs) + " ms"; break;
    default: break;
    }

    g.setColour(rowIsSelected ? juce::Colours::white : juce::Colours::lightgrey);
    g.setFont(juce::Font(juce::FontOptions(14.0f)));
    g.drawText(text, 4, 0, width - 8, height, juce::Justification::centredLeft);
}

void PluginManagerEditor::sortOrderChanged(int newSortColumnId, bool isForwards)
{
    sortColumn = newSortColumnId;
    sortForwards = isForwards;

    std::sort(displayRows.begin(), displayRows.end(),
        [this](const PluginDatabaseManager::PluginInfo& a, const PluginDatabaseManager::PluginInfo& b)
        {
            int result = 0;
            switch (sortColumn)
            {
            case 1: result = a.name.compareNatural(b.name); break;
            case 2: result = a.vendor.compareNatural(b.vendor); break;
            case 3: result = a.version.compareNatural(b.version); break;
            case 4: result = a.format.compareNatural(b.format); break;
            case 5: result = a.isInstrument ? -1 : 1; break;
            case 6: result = (a.isVerified ? 0 : 1) - (b.isVerified ? 0 : 1); break;
            case 7: result = (a.loadTimeMs < b.loadTimeMs) ? -1 : (a.loadTimeMs > b.loadTimeMs) ? 1 : 0; break;
            default: result = 0;
            }
            return isForwards ? (result < 0) : (result > 0);
        });

    pluginTable.updateContent();
}

