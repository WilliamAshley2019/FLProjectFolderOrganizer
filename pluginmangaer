bool PluginHostingModule::LoadAndExtractInfo(const juce::File& pluginFile, PluginDescription& outDesc)
{
    outDesc = PluginDescription(); // reset

    // If it's a VST3 bundle, we can extract metadata without loading
    if (IsVST3Bundle(pluginFile))
    {
        if (ExtractVST3Metadata(pluginFile, outDesc))
            return true;
        // If extraction fails, fall back to loading
    }

    std::unique_ptr<juce::AudioPluginInstance> instance;
    juce::String error;
    auto startTime = juce::Time::getMillisecondCounterHiRes();

    if (!LoadPluginInstance(pluginFile, instance, error))
    {
        outDesc.errorMessage = error;
        return false;
    }

    outDesc.loadTimeMs = (int)(juce::Time::getMillisecondCounterHiRes() - startTime);

    if (!ExtractMetadataFromInstance(*instance, outDesc))
    {
        outDesc.errorMessage = "Failed to extract metadata after loading.";
        return false;
    }

    outDesc.isVerified = true;
    return true;
}

bool PluginHostingModule::QuickTestLoad(const juce::File& pluginFile, juce::String& outError)
{
    std::unique_ptr<juce::AudioPluginInstance> instance;
    return LoadPluginInstance(pluginFile, instance, outError);
}

bool PluginHostingModule::LoadPluginInstance(const juce::File& pluginFile, std::unique_ptr<juce::AudioPluginInstance>& outInstance, juce::String& outError)
{
    // Find the appropriate format
    juce::AudioPluginFormat* format = nullptr;
    for (auto* f : formatManager.getFormats())
    {
        if (f->getName() == "VST3" && pluginFile.getFileExtension() == ".vst3")
        {
            format = f;
            break;
        }
        else if (f->getName() == "VST" && pluginFile.getFileExtension() == ".dll")
        {
            format = f;
            break;
        }
        else if (f->getName() == "AudioUnit" && pluginFile.getFileExtension() == ".component")
        {
            format = f;
            break;
        }
        else if (f->getName() == "CLAP" && pluginFile.getFileExtension() == ".clap")
        {
            format = f;
            break;
        }
    }

    if (format == nullptr)
    {
        outError = "Unsupported plugin format for file: " + pluginFile.getFullPathName();
        return false;
    }

    // Create a plugin description from the file
    juce::PluginDescription desc;
    desc.fileOrIdentifier = pluginFile.getFullPathName();
    desc.pluginFormatName = format->getName();

    // Try to create the instance
    juce::String error;
    auto* instance = format->createInstance(desc, error);
    if (instance == nullptr)
    {
        outError = "Failed to create plugin instance: " + error;
        return false;
    }

    outInstance.reset(instance);
    return true;
}

bool PluginHostingModule::ExtractMetadataFromInstance(juce::AudioPluginInstance& instance, PluginDescription& outDesc)
{
    juce::PluginDescription desc = instance.getPluginDescription();

    outDesc.name       = desc.name;
    outDesc.vendor     = desc.manufacturerName;
    outDesc.version    = desc.version;
    outDesc.uid        = desc.uniqueIdString;
    outDesc.format     = GetPluginFormatString(instance.getPluginFormat());
    outDesc.isInstrument = desc.isInstrument;
    outDesc.isVerified = true;

    return true;
}

juce::String PluginHostingModule::GetPluginFormatString(const juce::AudioPluginFormat* format)
{
    if (format == nullptr) return "Unknown";
    juce::String name = format->getName();
    if (name == "VST") return "VST2";
    if (name == "VST3") return "VST3";
    if (name == "AudioUnit") return "AU";
    if (name == "CLAP") return "CLAP";
    if (name == "AAX") return "AAX";
    return name;
}

bool PluginHostingModule::IsVST3Bundle(const juce::File& file) const
{
    return file.isDirectory() && file.getFileExtension() == ".vst3";
}

bool PluginHostingModule::ExtractVST3Metadata(const juce::File& bundleFile, PluginDescription& outDesc)
{
    // VST3 bundles have a Contents/Resources/Plugin.plist (or moduleinfo.json in newer versions)
    // We'll try to parse the .plist using juce::XmlDocument.

    juce::File plistFile = bundleFile.getChildFile("Contents/Resources/Plugin.plist");
    if (!plistFile.existsAsFile())
        return false;

    auto xml = juce::XmlDocument::parse(plistFile);
    if (xml == nullptr)
        return false;

    // Parse the plist XML to extract name, vendor, version, UID, etc.
    // This is a simplified example; actual plist may have different structure.
    // In practice, we could use a proper plist parser.

    // For demonstration, we'll just scan for key-value pairs.
    // This is not robust but shows the idea.

    auto* dict = xml->getChildByName("dict");
    if (dict == nullptr)
        return false;

    // Iterate through children to find keys
    for (auto* child = dict->getFirstChildElement(); child != nullptr; child = child->getNextElement())
    {
        if (child->getTagName() == "key")
        {
            juce::String key = child->getAllSubText();
            auto* next = child->getNextElement();
            if (next == nullptr) continue;
            juce::String value = next->getAllSubText();

            if (key == "name") outDesc.name = value;
            else if (key == "vendor") outDesc.vendor = value;
            else if (key == "version") outDesc.version = value;
            else if (key == "uniqueID") outDesc.uid = value;
            else if (key == "type")
            {
                // 'type' could be "instrument" or "effect"
                if (value.containsIgnoreCase("instrument"))
                    outDesc.isInstrument = true;
                else
                    outDesc.isInstrument = false;
            }
        }
    }

    outDesc.format = "VST3";
    outDesc.isVerified = true;
    return true;
}
